# .env.example — Variables d'entorn requerides
# Copiar a .env i omplir valors reals. MAI versionar .env.

ENV=development
LOG_LEVEL=info
DRY_RUN=false

# Font CMS (si requereix autenticació)
SOURCE_API_KEY=
SOURCE_USERNAME=
SOURCE_PASSWORD=

# Destí
DEST_URL=
DEST_API_KEY=
DEST_USERNAME=
DEST_PASSWORD=
