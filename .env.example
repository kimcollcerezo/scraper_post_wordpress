# .env.example — Variables d'entorn requerides
# Copiar a .env i omplir valors reals. MAI versionar .env.

ENV=development
LOG_LEVEL=info

# WordPress origen
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# Despertare Import API
DESPERTARE_IMPORT_BASE_URL=
DESPERTARE_IMPORT_TOKEN=
IMPORT_API_SECRET=
